# =============================================================================
# Rate Freak CMS - Production Environment Variables
# Copy this file to .env.production and fill in your values
# =============================================================================

# PostgreSQL connection string (your existing instance)
DATABASE_URL=postgresql://user:password@host:5432/rate_freak

# A random secret used to encrypt JWT tokens (generate with: openssl rand -hex 32)
PAYLOAD_SECRET=

# The public URL of your site, no trailing slash (e.g. https://ratefreak.com)
NEXT_PUBLIC_SERVER_URL=https://yourdomain.com

# Secret used to authenticate cron jobs (generate with: openssl rand -hex 16)
CRON_SECRET=

# Used to validate preview requests (generate with: openssl rand -hex 16)
PREVIEW_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# API Keys
DEEZER_API_ENDPOINT=https://api.deezer.com/search/album
OMDB_API_KEY_URL=
COMIC_VINE_API_KEY_URL=
COMIC_VINE_API_KEY=
ANI_LIST_API_URL=
HARDCOVER_BEARER_TOKEN=
